#!/data/data/com.termux/files/usr/bin/bash

SOURCE="${BASH_SOURCE[0]}"

# resolver symlink si existe
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done

BIN_DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"

# root del proyecto
OMNI_PATH="$(cd "$BIN_DIR/.." && pwd)"

# cargar bootstrap
source "$OMNI_PATH/utils/bootstrap.sh"

# cargar entorno
import "@/utils/env"

# ===== CHECK UPDATES =====
check_for_updates() {
  local version_file="$OMNI_CACHE/last_version_check"
  local current_time=$(date +%s)
  local check_interval=86400  # 24 horas en segundos
  local last_check=0

  if [[ -f "$version_file" ]]; then
    last_check=$(cat "$version_file" 2>/dev/null | head -1)
  fi

  if (( current_time - last_check < check_interval )); then
    return 0
  fi

  mkdir -p "$OMNI_CACHE"
  echo "$current_time" > "$version_file"

  (
    local remote_version=$(curl -fsSL "https://raw.githubusercontent.com/israel676767/omni/main/omni/utils/env.sh" 2>/dev/null | grep "OMNI_VERSION=" | cut -d'"' -f2)
    local local_version="$OMNI_VERSION"
    if [[ -n "$remote_version" ]] && [[ "$remote_version" != "$local_version" ]]; then
      echo "$remote_version" > "$OMNI_CACHE/new_version"
    fi
  ) &>/dev/null &
}

show_update_notification() {
  local new_version_file="$OMNI_CACHE/new_version"
  if [[ -f "$new_version_file" ]]; then
    local new_version=$(cat "$new_version_file")
    echo
    separator_section "Update Available"
    echo
    log_warn "New version available: ${D_GREEN}$new_version${D_NC} (current: ${D_CYAN}$OMNI_VERSION${D_NC})"
    echo
    list_item "Run: ${D_CYAN}omni update${D_NC} to update"
    echo
  fi
}

if [[ "$1" != "update" ]] && [[ "$1" != "uninstall" ]] && [[ "$1" != "reinstall" ]]; then
  check_for_updates
  import "@/utils/log"
  import "@/utils/colors"
  show_update_notification
fi

# cargar CLI unificado (com TUI + help)
import "@/cli/omni"

omni_main "$@"
